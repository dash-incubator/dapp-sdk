{
    "author": "ICJR",
    "dependencies": {
        "@esportsplus/dot": "^0.0.3",
        "browser-image-compression": "^1.0.17",
        "dash": "*",
        "ipfs-core": "*",
        "localforage": "^1.10.0"
    },
    "description": "Dash Dapp SDK",
    "devDependencies": {
        "bignumber.js": "^9.0.1",
        "glob": "^7.1.7",
        "node-polyfill-webpack-plugin": "^1.1.4",
        "npm-run-all": "^4.1.5",
        "ts-loader": "^9.2.6",
        "tsconfig-paths-webpack-plugin": "^3.5.2",
        "typescript": "^4.5.2",
        "webpack": "^5.64.4",
        "webpack-cli": "^4.9.1"
    },
    "name": "@dash-incubator/dapp-sdk",
    "main": "./build/index.js",
    "private": false,
    "scripts": {
        "build": "run-s build:ts build:web",
        "build:ts": "tsc",
        "build:web": "webpack --config webpack.typescript.config.js --env=filename=dapp --env=input=%INIT_CWD%/src --env=output=%INIT_CWD%/dist --env=production=true",
        "-": "-",
        "prepare": "npm run build",
        "prepublishOnly": "npm run build"
    },
    "types": "./build/index.d.ts",
    "unpkg": "./dist/dapp.min.js",
    "version": "0.3.2"
}
